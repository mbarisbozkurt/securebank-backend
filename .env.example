# Docker Compose PostgreSQL settings
POSTGRES_DB=securebank
POSTGRES_USER=securebank
POSTGRES_PASSWORD=change_me_to_a_local_password
POSTGRES_PORT=5433
BACKEND_PORT=8081

# Docker Compose RabbitMQ settings
RABBITMQ_DEFAULT_USER=securebank
RABBITMQ_DEFAULT_PASS=change_me_to_a_local_rabbitmq_password
RABBITMQ_PORT=5672
RABBITMQ_MANAGEMENT_PORT=15672
RABBITMQ_USERNAME=securebank
RABBITMQ_PASSWORD=change_me_to_a_local_rabbitmq_password
RABBITMQ_EVENTS_EXCHANGE=securebank.events
RABBITMQ_EVENTS_DEAD_LETTER_EXCHANGE=securebank.events.dlx
RABBITMQ_TRANSFER_COMPLETED_QUEUE=securebank.transfer.completed
RABBITMQ_TRANSFER_COMPLETED_DEAD_LETTER_QUEUE=securebank.transfer.completed.dlq
RABBITMQ_TRANSFER_COMPLETED_ROUTING_KEY=transfer.completed
RABBITMQ_TRANSFER_COMPLETED_DEAD_LETTER_ROUTING_KEY=transfer.completed.dlq
RABBITMQ_RETRY_MAX_ATTEMPTS=3
RABBITMQ_RETRY_INITIAL_INTERVAL_MS=2000
RABBITMQ_RETRY_MULTIPLIER=2.0
RABBITMQ_RETRY_MAX_INTERVAL_MS=10000

# Local non-Docker Spring Boot settings
DB_URL=jdbc:postgresql://localhost:5432/securebank
DB_USERNAME=securebank
DB_PASSWORD=change_me_to_a_local_password

JWT_SECRET=replace-with-a-long-secure-secret-at-least-32-chars
JWT_EXPIRATION=3600000
REFRESH_TOKEN_EXPIRATION=604800000
REFRESH_TOKEN_COOKIE_SECURE=false
REFRESH_TOKEN_COOKIE_SAME_SITE=Strict
CORS_ALLOWED_ORIGINS=http://localhost:5173
JPA_DDL_AUTO=validate
JPA_SHOW_SQL=false
JPA_FORMAT_SQL=false
FLYWAY_ENABLED=true
FLYWAY_BASELINE_ON_MIGRATE=true

# Notification service persistence settings
NOTIFICATION_JPA_DDL_AUTO=validate
NOTIFICATION_FLYWAY_ENABLED=true
NOTIFICATION_FLYWAY_BASELINE_ON_MIGRATE=true
NOTIFICATION_FLYWAY_BASELINE_VERSION=0
NOTIFICATION_FLYWAY_TABLE=flyway_schema_history_notification

ADMIN_SEED_ENABLED=true
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=change_me_to_a_local_admin_password

RATE_LIMIT_ENABLED=true
RATE_LIMIT_WINDOW_SECONDS=60
RATE_LIMIT_GENERAL_LIMIT=600
RATE_LIMIT_SENSITIVE_LIMIT=60

# Notification service email settings
MAIL_FROM=no-reply@securebank.local
MAIL_SENDER_MODE=logging
MAIL_HOST=sandbox.smtp.mailtrap.io
MAIL_PORT=2525
MAIL_USERNAME=change_me_to_mail_provider_username
MAIL_PASSWORD=change_me_to_mail_provider_password
MAIL_SMTP_AUTH=true
MAIL_SMTP_STARTTLS_ENABLE=true
